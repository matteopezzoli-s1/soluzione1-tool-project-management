# ============================================================
# backend/.env.example — copia in .env e compila i valori
# ============================================================

# Google OAuth (Google Cloud Console → API & Services → Credentials)
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=cambia-questo-in-produzione

# URL del frontend (senza slash finale)
FRONTEND_URL=http://localhost:5173

# URL pubblico di questo backend (usato per costruire il callback URL)
BACKEND_URL=http://localhost:8080

# Porta del server
PORT=8080

# Database Prisma (lascia vuoto se non usi ancora il DB)
# DATABASE_URL=postgresql://user:password@localhost:5432/s1gantt
