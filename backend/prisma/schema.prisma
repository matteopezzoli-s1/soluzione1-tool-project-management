generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ACCOUNT
  PM
  BOARD
  DEVHUB
}

enum TipoAttivita {
  STANDARD
  BUCKET
}

enum TipoContratto {
  MANUTENZIONE
  MANUTENZIONE_AMS
}

model User {
  id             String     @id @default(cuid())
  googleId       String?    @unique @map("google_id")
  email          String?    @unique
  name           String?
  firstName      String?    @map("first_name")
  lastName       String?    @map("last_name")
  avatarUrl      String?    @map("avatar_url")
  roles          UserRole[] @default([])
  deletedAt      DateTime?  @map("deleted_at")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  ownedProjects  Project[]       @relation("ProjectOwner")
  memberships    ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")
  comments       TaskComment[]
  activityLogs   ActivityLog[]

  progettiDevHub  Progetto[]  @relation("ProgettoDevHub")
  progettiPO      Progetto[]  @relation("ProgettoPO")
  progettiPmRiferimento Progetto[] @relation("ProgettoPmRiferimento")
  attivitaPM      Attivita[]  @relation("AttivitaPM")
  clientiAccount  Cliente[]   @relation("ClienteAccount")
  attivitaAccount Attivita[]  @relation("AttivitaAccount")
  attivitaPresaleAssegnate Attivita[] @relation("AttivitaPresaleAssegnatario")
  attivitaStatoLog         AttivitaStatoLog[]
  zohoImportSessions       ZohoImportSession[]

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  color        String        @default("#6366f1")
  status       ProjectStatus @default(ACTIVE)
  startDate    DateTime?     @map("start_date")
  endDate      DateTime?     @map("end_date")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  ownerId      String  @map("owner_id")
  owner        User    @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members      ProjectMember[]
  tasks        Task[]
  milestones   Milestone[]
  activityLogs ActivityLog[]

  @@index([ownerId])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model ProjectMember {
  id       String     @id @default(cuid())
  role     MemberRole @default(VIEWER)
  joinedAt DateTime   @default(now()) @map("joined_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  startDate      DateTime   @map("start_date")
  endDate        DateTime   @map("end_date")
  progress       Int        @default(0)
  color          String?
  sortOrder      Int        @default(0) @map("sort_order")
  estimatedHours Float?     @map("estimated_hours")
  loggedHours    Float      @default(0) @map("logged_hours")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  parentId    String?  @map("parent_id")
  parent      Task?    @relation("TaskChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]   @relation("TaskChildren")

  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId  String?  @map("assignee_id")
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId   String   @map("creator_id")
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id])

  milestoneId String?    @map("milestone_id")
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  tags         TaskTag[]
  comments     TaskComment[]
  dependencies TaskDependency[] @relation("DependentTask")
  dependents   TaskDependency[] @relation("PrerequisiteTask")
  activityLogs ActivityLog[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([parentId])
  @@index([startDate, endDate])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TaskDependency {
  id             String         @id @default(cuid())
  type           DependencyType @default(FINISH_TO_START)
  lagDays        Int            @default(0) @map("lag_days")

  dependentId    String  @map("dependent_id")
  dependent      Task    @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)

  prerequisiteId String  @map("prerequisite_id")
  prerequisite   Task    @relation("PrerequisiteTask", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([dependentId, prerequisiteId])
  @@map("task_dependencies")
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

model Milestone {
  id          String   @id @default(cuid())
  name        String
  description String?
  date        DateTime
  reached     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  projectId   String  @map("project_id")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([projectId])
  @@map("milestones")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#94a3b8")
  tasks TaskTag[]

  @@map("tags")
}

model TaskTag {
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String @map("tag_id")
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  taskId    String @map("task_id")
  task      Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  String @map("author_id")
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  taskId    String?  @map("task_id")
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([projectId])
  @@index([userId])
  @@map("activity_logs")
}

// ── Clienti ───────────────────────────────────────────────────

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  referente String?
  email     String?
  telefono  String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accountId String?  @map("account_id")
  account   User?    @relation("ClienteAccount", fields: [accountId], references: [id], onDelete: SetNull)

  progetti  Progetto[]
  attivita  Attivita[]
  contratti Contratto[]

  @@index([accountId])
  @@map("clienti")
}

// ── Progetti & Prodotti ─────────────────────────────────────────
// Stessa struttura per progetti clienti e prodotti interni, distinti
// dal campo `tipo` ("CLIENTE" | "PRODOTTO") — pensata per un futuro
// import da un'unica fonte esterna (es. Zoho) senza dover mappare
// due entità diverse. I prodotti non hanno cliente ma un PO
// (riferimento a User con ruolo PM) e un colore per la roadmap.

model Progetto {
  id          String    @id @default(cuid())
  nome        String
  descrizione String?
  tipo        String    @default("CLIENTE") @map("tipo")
  stato       String    @default("ATTIVO")
  colore      String?
  dataInizio  DateTime? @map("data_inizio")
  dataFine    DateTime? @map("data_fine")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  clienteId   String?   @map("cliente_id")
  cliente     Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  poId        String? @map("po_id")
  po          User?   @relation("ProgettoPO", fields: [poId], references: [id], onDelete: SetNull)

  pmRiferimentoId String? @map("pm_riferimento_id")
  pmRiferimento   User?   @relation("ProgettoPmRiferimento", fields: [pmRiferimentoId], references: [id], onDelete: SetNull)

  responsabileDevHubId String? @map("responsabile_dev_hub_id")
  responsabileDevHub   User?   @relation("ProgettoDevHub", fields: [responsabileDevHubId], references: [id], onDelete: SetNull)

  attivita     Attivita[]
  roadmapItems RoadmapItem[]
  contratti    ContrattoApplicazione[]

  @@index([clienteId])
  @@index([pmRiferimentoId])
  @@index([tipo])
  @@index([responsabileDevHubId])
  @@map("progetti")
}

// ── Elenco Attività ───────────────────────────────────────────

model Attivita {
  id                       String       @id @default(cuid())
  cliente                  String
  progetto                 String
  attivita                 String
  // BUCKET: giornate vendute "a monte" da monitorare rispetto al fatturato,
  // non rispetto al consuntivo (obiettivo: vendute ≈ fatturate). Per queste
  // righe `stato` usa due valori fissi (APERTA/CHIUSA), non StatoAttivitaConfig.
  tipo                     TipoAttivita @default(STANDARD)
  giornateVendute          Decimal?     @map("giornate_vendute") @db.Decimal(10, 2)
  giornateFatturate        Decimal?     @map("giornate_fatturate") @db.Decimal(10, 2)
  giornateConsuntivate     Decimal?     @map("giornate_consuntivate") @db.Decimal(10, 2)
  riferimentoOrdineVendita String?      @map("riferimento_ordine_vendita")
  stato                    String       @default("IN_CORSO")
  inizio                   DateTime?
  deadline                 DateTime?
  note                     String?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  clienteId                String?         @map("cliente_id")
  clienteRel               Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  progettoId               String?         @map("progetto_id")
  progettoRel              Progetto?       @relation(fields: [progettoId], references: [id], onDelete: SetNull)

  accountId                String?         @map("account_id")
  accountRel               User?           @relation("AttivitaAccount", fields: [accountId], references: [id], onDelete: SetNull)

  // PM di riferimento dell'attività (un solo PM per attività). Nullable:
  // un'attività può non avere ancora un PM assegnato.
  pmId                     String?         @map("pm_id")
  pm                       User?           @relation("AttivitaPM", fields: [pmId], references: [id], onDelete: SetNull)

  // ── Presale (valorizzati solo mentre l'attività è in uno stato isPresale) ──
  presaleLinkRequisiti     String?         @map("presale_link_requisiti")
  presaleLinkStima         String?         @map("presale_link_stima")
  presaleLinkOfferta       String?         @map("presale_link_offerta")
  // Cartella Drive del file analisi (valorizzata quando il file è scelto col
  // picker): il picker della fase Stima si apre bloccato su questa cartella.
  presaleDriveFolderId     String?         @map("presale_drive_folder_id")
  presaleGiornateStimate   Decimal?        @map("presale_giornate_stimate") @db.Decimal(10, 2)
  presaleScadenzaStima     DateTime?       @map("presale_scadenza_stima")
  presaleTipoIntervento    String?         @map("presale_tipo_intervento") // NUOVO_PROGETTO | MODIFICA
  presaleNotePerFase       Json?           @map("presale_note_per_fase")
  presaleAssegnatarioId    String?         @map("presale_assegnatario_id")
  presaleAssegnatario      User?           @relation("AttivitaPresaleAssegnatario", fields: [presaleAssegnatarioId], references: [id], onDelete: SetNull)
  // Codici fase (ANALISI_INIZIALE, PRESA_IN_CARICO, …) per cui la mail SAIOT è
  // già stata inviata: evita doppioni quando la card viene ri-salvata.
  presaleEmailFasiInviate  String[]        @default([]) @map("presale_email_fasi_inviate")

  milestones               GanttMilestone[]
  statoLog                 AttivitaStatoLog[]
  consuntiviMese           AttivitaConsuntivoMese[]

  @@index([cliente, progetto])
  @@index([stato])
  @@index([clienteId])
  @@index([progettoId])
  @@index([accountId])
  @@index([pmId])
  @@index([presaleAssegnatarioId])
  @@map("attivita")
}

// ── Contratti di assistenza / AMS ─────────────────────────────
// Un contratto appartiene a un Cliente e copre 1..N applicazioni
// (= Progetto, tipo "CLIENTE"). `anno` è l'anno di competenza dichiarato
// (come i fogli Excel annuali); le date possono comunque sforare l'anno.
// `dataFine` null = contratto continuativo / a tacito rinnovo.
// Il PM non è un campo: si eredita in sola lettura dai pmRiferimento dei
// progetti coperti. `fatturato` è un flag secco (niente importi parziali).
// Il contratto ha il SUO ordine di vendita, come le attività: l'import
// consuntivi Zoho aggiorna `giornateConsuntivate` per corrispondenza di
// codice GO-ORDV — nessun collegamento manuale ad attività.

model Contratto {
  id                       String        @id @default(cuid())
  titolo                   String
  tipo                     TipoContratto @default(MANUTENZIONE)
  anno                     Int
  stato                    String        @default("IN_DEFINIZIONE")
  dataInizio               DateTime?     @map("data_inizio")
  dataFine                 DateTime?     @map("data_fine")
  // Riferimento del confronto economico: consumato (giornate consuntivate
  // × costo medio) vs importo totale del contratto.
  importoTotale            Decimal?      @map("importo_totale") @db.Decimal(12, 2)
  fatturato                Boolean       @default(false)
  // Riferimento dell'ordine di vendita (GO-ORDV) del contratto: l'import
  // consuntivi Zoho lo usa per agganciare le ore, come per le attività.
  riferimentoOrdineVendita String?       @map("riferimento_ordine_vendita")
  // Giornate consuntivate agganciate dall'import Zoho via ordine di vendita.
  giornateConsuntivate     Decimal?      @map("giornate_consuntivate") @db.Decimal(10, 2)
  driveUrl                 String?       @map("drive_url")
  driveFolderId            String?       @map("drive_folder_id")
  note                     String?
  createdAt                DateTime      @default(now()) @map("created_at")
  updatedAt                DateTime      @updatedAt @map("updated_at")

  clienteId                String        @map("cliente_id")
  cliente                  Cliente       @relation(fields: [clienteId], references: [id], onDelete: Restrict)

  applicazioni             ContrattoApplicazione[]

  @@index([clienteId])
  @@index([anno])
  @@index([stato])
  @@map("contratti")
}

model ContrattoApplicazione {
  contrattoId String    @map("contratto_id")
  progettoId  String    @map("progetto_id")
  contratto   Contratto @relation(fields: [contrattoId], references: [id], onDelete: Cascade)
  progetto    Progetto  @relation(fields: [progettoId], references: [id], onDelete: Cascade)

  @@id([contrattoId, progettoId])
  @@map("contratto_applicazioni")
}

// Dettaglio mensile di un'attività: giornate consuntivate (alimentate
// dall'import Zoho, che aggrega i timelog per mese) e giornate fatturate
// (compilate a mano dal PM per il rapportino degli ordini bucket).
// `mese` in formato "YYYY-MM". Per le attività BUCKET il totale
// giornateFatturate sull'Attivita è mantenuto pari alla somma dei mesi.
model AttivitaConsuntivoMese {
  id                   String   @id @default(cuid())
  attivitaId           String   @map("attivita_id")
  attivita             Attivita @relation(fields: [attivitaId], references: [id], onDelete: Cascade)
  mese                 String
  giornateConsuntivate Decimal? @map("giornate_consuntivate") @db.Decimal(10, 2)
  giornateFatturate    Decimal? @map("giornate_fatturate") @db.Decimal(10, 2)
  createdAt            DateTime @default(now()) @map("created_at")
  updatedAt            DateTime @updatedAt @map("updated_at")

  @@unique([attivitaId, mese])
  @@map("attivita_consuntivi_mese")
}

// Storico dei passaggi di stato di un'attività — alimenta la timeline del
// drawer Presale. Un record per transizione: chi ha spostato la card, da/a
// quale fase, quando. statoDa è null solo per la riga di creazione.
model AttivitaStatoLog {
  id         String   @id @default(cuid())
  attivitaId String   @map("attivita_id")
  attivita   Attivita @relation(fields: [attivitaId], references: [id], onDelete: Cascade)
  statoDa    String?  @map("stato_da")
  statoA     String   @map("stato_a")
  userId     String?  @map("user_id")
  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([attivitaId])
  @@map("attivita_stato_log")
}

// ── Gantt Milestones ──────────────────────────────────────────

model GanttMilestone {
  id         String   @id @default(cuid())
  activityId String   @map("activity_id")
  title      String
  date       DateTime
  color      String   @default("#F59E0B")
  icon       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  activity   Attivita @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("gantt_milestones")
}

// ── Configurazione stati ──────────────────────────────────────

model StatoAttivitaConfig {
  id                 String   @id @default(cuid())
  chiave             String   @unique
  label              String
  colore             String   @default("#94a3b8")
  isArchiviato       Boolean  @default(false) @map("is_archiviato")
  escludiDaConteggio Boolean  @default(false) @map("escludi_da_conteggio")
  isPresale          Boolean  @default(false) @map("is_presale")
  ordine             Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("stato_attivita_config")
}

model StatoProgettoConfig {
  id           String   @id @default(cuid())
  chiave       String   @unique
  label        String
  colore       String   @default("#94a3b8")
  isArchiviato Boolean  @default(false) @map("is_archiviato")
  ordine       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("stato_progetto_config")
}

model StatoContrattoConfig {
  id        String   @id @default(cuid())
  chiave    String   @unique
  label     String
  colore    String   @default("#94a3b8")
  // Contratto concluso/chiuso: escluso dal banner scadenze.
  isChiuso  Boolean  @default(false) @map("is_chiuso")
  ordine    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("stato_contratto_config")
}

model StatoRoadmapConfig {
  id           String   @id @default(cuid())
  chiave       String   @unique
  label        String
  colore       String   @default("#94a3b8")
  isArchiviato Boolean  @default(false) @map("is_archiviato")
  ordine       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("stato_roadmap_config")
}

// ── Roadmap Prodotti ──────────────────────────────────────────
// Una riga per iniziativa pianificata su un prodotto (tipo="PRODOTTO"
// in Progetto), raggruppata per anno+quarter. `ordine` è la priorità
// drag&drop, scoped a prodotto+quarter (vedi PATCH /:id/posizione).

model RoadmapItem {
  id           String    @id @default(cuid())
  progettoId   String    @map("progetto_id")
  progetto     Progetto  @relation(fields: [progettoId], references: [id], onDelete: Cascade)

  anno         Int
  quarter      String?   // "Q1".."Q4", null = non pianificato
  dataDeadline DateTime? @map("data_deadline")
  titolo       String
  descrizione  String?
  stato        String    @default("DA_FARE")
  analisiUrl   String?   @map("analisi_url")
  stimaGg      Decimal?  @map("stima_gg") @db.Decimal(10, 2)
  ordine       Int       @default(0)

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  tags         RoadmapItemTag[]

  @@index([progettoId])
  @@index([anno, quarter])
  @@index([stato])
  @@map("roadmap_items")
}

model RoadmapTag {
  id        String   @id @default(cuid())
  label     String   @unique
  colore    String   @default("#94a3b8")
  ordine    Int      @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  items     RoadmapItemTag[]

  @@map("roadmap_tags")
}

model RoadmapItemTag {
  roadmapItemId String      @map("roadmap_item_id")
  tagId         String      @map("tag_id")
  roadmapItem   RoadmapItem @relation(fields: [roadmapItemId], references: [id], onDelete: Cascade)
  tag           RoadmapTag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([roadmapItemId, tagId])
  @@map("roadmap_item_tags")
}
// Storico delle sessioni di import consuntivi da Zoho Projects — alimenta la
// sezione "Storico import" della pagina Consuntivi Zoho. `righe` è lo snapshot
// JSON dei delta applicati: [{attivitaId, cliente, progetto, attivita, codice,
// prima, dopo, delta}], solo le attività il cui valore è effettivamente
// cambiato. Le sessioni più vecchie di 5 giorni vengono eliminate a ogni
// lettura/scrittura dello storico.
model ZohoImportSession {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  righe     Json
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@map("zoho_import_sessions")
}

// Configurazione applicativa key-value (singole righe: chiave → valore stringa).
// Usata per i parametri delle notifiche Presale via SAIOT (endpoint, codici,
// mail gruppo DevHub, interruttore invii). Editabile dalla schermata Impostazioni.
model AppConfig {
  chiave    String   @id
  valore    String
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("app_config")
