generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model ProjectManager {
  id        String   @id @default(cuid())
  firstName String?  @map("first_name")
  lastName  String   @map("last_name")
  email     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  attivita     AttivitaPM[]
  progettiPO   Progetto[]   @relation("ProgettoPO")

  @@map("project_managers")
}

model Account {
  id        String   @id @default(cuid())
  firstName String?  @map("first_name")
  lastName  String   @map("last_name")
  email     String?  @unique
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  clienti   Cliente[]
  attivita  Attivita[]

  @@map("accounts")
}

model User {
  id             String   @id @default(cuid())
  googleId       String   @unique @map("google_id")
  email          String   @unique
  name           String
  avatarUrl      String?  @map("avatar_url")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  ownedProjects  Project[]       @relation("ProjectOwner")
  memberships    ProjectMember[]
  assignedTasks  Task[]          @relation("TaskAssignee")
  createdTasks   Task[]          @relation("TaskCreator")
  comments       TaskComment[]
  activityLogs   ActivityLog[]

  @@map("users")
}

model Project {
  id           String        @id @default(cuid())
  name         String
  description  String?
  color        String        @default("#6366f1")
  status       ProjectStatus @default(ACTIVE)
  startDate    DateTime?     @map("start_date")
  endDate      DateTime?     @map("end_date")
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  ownerId      String  @map("owner_id")
  owner        User    @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  members      ProjectMember[]
  tasks        Task[]
  milestones   Milestone[]
  activityLogs ActivityLog[]

  @@index([ownerId])
  @@map("projects")
}

enum ProjectStatus {
  ACTIVE
  ON_HOLD
  COMPLETED
  ARCHIVED
}

model ProjectMember {
  id       String     @id @default(cuid())
  role     MemberRole @default(VIEWER)
  joinedAt DateTime   @default(now()) @map("joined_at")

  projectId String  @map("project_id")
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  userId    String  @map("user_id")
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, userId])
  @@index([userId])
  @@map("project_members")
}

enum MemberRole {
  OWNER
  EDITOR
  VIEWER
}

model Task {
  id             String     @id @default(cuid())
  title          String
  description    String?
  status         TaskStatus @default(TODO)
  priority       Priority   @default(MEDIUM)
  startDate      DateTime   @map("start_date")
  endDate        DateTime   @map("end_date")
  progress       Int        @default(0)
  color          String?
  sortOrder      Int        @default(0) @map("sort_order")
  estimatedHours Float?     @map("estimated_hours")
  loggedHours    Float      @default(0) @map("logged_hours")
  createdAt      DateTime   @default(now()) @map("created_at")
  updatedAt      DateTime   @updatedAt @map("updated_at")

  parentId    String?  @map("parent_id")
  parent      Task?    @relation("TaskChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children    Task[]   @relation("TaskChildren")

  projectId   String   @map("project_id")
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assigneeId  String?  @map("assignee_id")
  assignee    User?    @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  creatorId   String   @map("creator_id")
  creator     User     @relation("TaskCreator", fields: [creatorId], references: [id])

  milestoneId String?    @map("milestone_id")
  milestone   Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)

  tags         TaskTag[]
  comments     TaskComment[]
  dependencies TaskDependency[] @relation("DependentTask")
  dependents   TaskDependency[] @relation("PrerequisiteTask")
  activityLogs ActivityLog[]

  @@index([projectId])
  @@index([assigneeId])
  @@index([parentId])
  @@index([startDate, endDate])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  IN_REVIEW
  DONE
  CANCELLED
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model TaskDependency {
  id             String         @id @default(cuid())
  type           DependencyType @default(FINISH_TO_START)
  lagDays        Int            @default(0) @map("lag_days")

  dependentId    String  @map("dependent_id")
  dependent      Task    @relation("DependentTask", fields: [dependentId], references: [id], onDelete: Cascade)

  prerequisiteId String  @map("prerequisite_id")
  prerequisite   Task    @relation("PrerequisiteTask", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@unique([dependentId, prerequisiteId])
  @@map("task_dependencies")
}

enum DependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
  START_TO_FINISH
}

model Milestone {
  id          String   @id @default(cuid())
  name        String
  description String?
  date        DateTime
  reached     Boolean  @default(false)
  createdAt   DateTime @default(now()) @map("created_at")

  projectId   String  @map("project_id")
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@index([projectId])
  @@map("milestones")
}

model Tag {
  id    String @id @default(cuid())
  name  String @unique
  color String @default("#94a3b8")
  tasks TaskTag[]

  @@map("tags")
}

model TaskTag {
  taskId String @map("task_id")
  task   Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tagId  String @map("tag_id")
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([taskId, tagId])
  @@map("task_tags")
}

model TaskComment {
  id        String   @id @default(cuid())
  content   String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  taskId    String @map("task_id")
  task      Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)

  authorId  String @map("author_id")
  author    User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@map("task_comments")
}

model ActivityLog {
  id         String   @id @default(cuid())
  action     String
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  userId    String?  @map("user_id")
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  projectId String?  @map("project_id")
  project   Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  taskId    String?  @map("task_id")
  task      Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([projectId])
  @@index([userId])
  @@map("activity_logs")
}

// ── Clienti ───────────────────────────────────────────────────

model Cliente {
  id        String   @id @default(cuid())
  nome      String
  referente String?
  email     String?
  telefono  String?
  note      String?
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  accountId String?  @map("account_id")
  account   Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  progetti  Progetto[]
  attivita  Attivita[]

  @@index([accountId])
  @@map("clienti")
}

// ── Progetti & Prodotti ─────────────────────────────────────────
// Stessa struttura per progetti clienti e prodotti interni, distinti
// dal campo `tipo` ("CLIENTE" | "PRODOTTO") — pensata per un futuro
// import da un'unica fonte esterna (es. Zoho) senza dover mappare
// due entità diverse. I prodotti non hanno cliente ma un PO
// (riferimento a ProjectManager) e un colore per la roadmap.

model Progetto {
  id          String    @id @default(cuid())
  nome        String
  descrizione String?
  tipo        String    @default("CLIENTE") @map("tipo")
  stato       String    @default("ATTIVO")
  colore      String?
  dataInizio  DateTime? @map("data_inizio")
  dataFine    DateTime? @map("data_fine")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  clienteId   String?   @map("cliente_id")
  cliente     Cliente?  @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  poId        String?         @map("po_id")
  po          ProjectManager? @relation("ProgettoPO", fields: [poId], references: [id], onDelete: SetNull)

  attivita     Attivita[]
  roadmapItems RoadmapItem[]

  @@index([clienteId])
  @@index([tipo])
  @@map("progetti")
}

// ── Elenco Attività ───────────────────────────────────────────

model Attivita {
  id                       String   @id @default(cuid())
  cliente                  String
  progetto                 String
  attivita                 String
  giornateVendute          Decimal? @map("giornate_vendute") @db.Decimal(10, 2)
  giornateConsuntivate     Decimal? @map("giornate_consuntivate") @db.Decimal(10, 2)
  riferimentoOrdineVendita String?  @map("riferimento_ordine_vendita")
  stato                    String   @default("IN_CORSO")
  inizio                   DateTime?
  deadline                 DateTime?
  note                     String?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  clienteId                String?         @map("cliente_id")
  clienteRel               Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)

  progettoId               String?         @map("progetto_id")
  progettoRel              Progetto?       @relation(fields: [progettoId], references: [id], onDelete: SetNull)

  accountId                String?         @map("account_id")
  accountRel               Account?        @relation(fields: [accountId], references: [id], onDelete: SetNull)

  pms                      AttivitaPM[]
  milestones               GanttMilestone[]

  @@index([cliente, progetto])
  @@index([stato])
  @@index([clienteId])
  @@index([progettoId])
  @@index([accountId])
  @@map("attivita")
}

model AttivitaPM {
  attivitaId  String         @map("attivita_id")
  pmId        String         @map("pm_id")
  attivita    Attivita       @relation(fields: [attivitaId], references: [id], onDelete: Cascade)
  pm          ProjectManager @relation(fields: [pmId], references: [id], onDelete: Cascade)

  @@id([attivitaId, pmId])
  @@map("attivita_pms")
}

// ── Gantt Milestones ──────────────────────────────────────────

model GanttMilestone {
  id         String   @id @default(cuid())
  activityId String   @map("activity_id")
  title      String
  date       DateTime
  color      String   @default("#F59E0B")
  icon       String?
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  activity   Attivita @relation(fields: [activityId], references: [id], onDelete: Cascade)

  @@index([activityId])
  @@map("gantt_milestones")
}

// ── Configurazione stati ──────────────────────────────────────

model StatoAttivitaConfig {
  id                 String   @id @default(cuid())
  chiave             String   @unique
  label              String
  colore             String   @default("#94a3b8")
  isArchiviato       Boolean  @default(false) @map("is_archiviato")
  escludiDaConteggio Boolean  @default(false) @map("escludi_da_conteggio")
  ordine             Int      @default(0)
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("stato_attivita_config")
}

model StatoProgettoConfig {
  id           String   @id @default(cuid())
  chiave       String   @unique
  label        String
  colore       String   @default("#94a3b8")
  isArchiviato Boolean  @default(false) @map("is_archiviato")
  ordine       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("stato_progetto_config")
}

model StatoRoadmapConfig {
  id           String   @id @default(cuid())
  chiave       String   @unique
  label        String
  colore       String   @default("#94a3b8")
  isArchiviato Boolean  @default(false) @map("is_archiviato")
  ordine       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("stato_roadmap_config")
}

// ── Roadmap Prodotti ──────────────────────────────────────────
// Una riga per iniziativa pianificata su un prodotto (tipo="PRODOTTO"
// in Progetto), raggruppata per anno+quarter. `ordine` è la priorità
// drag&drop, scoped a prodotto+quarter (vedi PATCH /:id/posizione).

model RoadmapItem {
  id           String    @id @default(cuid())
  progettoId   String    @map("progetto_id")
  progetto     Progetto  @relation(fields: [progettoId], references: [id], onDelete: Cascade)

  anno         Int
  quarter      String?   // "Q1".."Q4", null = non pianificato
  dataDeadline DateTime? @map("data_deadline")
  titolo       String
  descrizione  String?
  stato        String    @default("DA_FARE")
  analisiUrl   String?   @map("analisi_url")
  stimaGg      Decimal?  @map("stima_gg") @db.Decimal(10, 2)
  ordine       Int       @default(0)

  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  @@index([progettoId])
  @@index([anno, quarter])
  @@index([stato])
  @@map("roadmap_items")
}